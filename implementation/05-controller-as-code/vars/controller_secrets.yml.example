---
# Copy to controller_secrets.yml, fill in real values, then encrypt:
#   ansible-vault encrypt vars/controller_secrets.yml
#
# Never commit the unencrypted file. Every task in configure_controller.yml
# that consumes these values runs with no_log: true.

# Cluster B's API URL and the token minted for the aap-vm-operator
# ServiceAccount. See ../../00-prerequisites.md, Cluster B, item 2.
ocpvirt_api_host: "https://api.cluster-b.example.com:6443"
ocpvirt_bearer_token: "<output of: oc create token aap-vm-operator -n vm-workloads --duration=8760h>"

# Private key whose public half is in every VM's ~/.ssh/authorized_keys.
# See ../../00-prerequisites.md, Cluster B, item 4.
vm_guest_ssh_private_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  ...
  -----END OPENSSH PRIVATE KEY-----

# NOT EXECUTED - reference only. No VMware infrastructure available in
# this environment. Only needed if apply_vmware_objects is ever set to
# true in configure_controller.yml.
vcenter_host: "vcenter.example.com"
vcenter_username: "svc-aap@vsphere.local"
vcenter_password: "<vcenter password>"
